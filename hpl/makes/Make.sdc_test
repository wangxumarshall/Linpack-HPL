#  
#  -- High Performance Computing Linpack Benchmark (HPL)                
#     SDC Fault Injection Test Module                                  
#  
include Make.inc
#
# ######################################################################
#
INCdep           = \
   $(INCdir)/hpl_misc.h   $(INCdir)/hpl_blas.h   $(INCdir)/hpl_auxil.h \
   $(INCdir)/hpl_pmisc.h  $(INCdir)/hpl_grid.h   $(INCdir)/hpl_comm.h  \
   $(INCdir)/hpl_pauxil.h $(INCdir)/hpl_panel.h  $(INCdir)/hpl_pfact.h \
   $(INCdir)/hpl_pgesv.h  $(INCdir)/hpl_sdc.h
#
## Executable name #####################################################
#
xsdc_test        = $(BINdir)/xhpl_sdc_test
#
## Object files ########################################################
#
HPL_sdc_test_obj = \
   HPL_sdc_test.o
#
## Targets #############################################################
#
all     : texe
#
texe    : texe.grd
#
texe.grd: $(HPL_sdc_test_obj) $(HPLlib)
	$(LINKER) $(LINKFLAGS) -o $(xsdc_test) $(HPL_sdc_test_obj) $(HPL_LIBS) -lm
	$(TOUCH) texe.grd
#
# ######################################################################
#
HPL_sdc_test.o     : ../HPL_sdc_test.c     $(INCdep)
	$(CC) -o $@ -c $(CCFLAGS)  ../HPL_sdc_test.c
#
# ######################################################################
#
clean            :
	$(RM) *.o *.grd
#
# ######################################################################
